@* InfoField.razor — drop in Shared/ or the same folder as AdminBookingsPage.razor *@
<div>
    <p class="text-[10px] uppercase tracking-widest font-bold text-muted-foreground">@Label</p>
    <div class="text-foreground mt-1">
        @if (ChildContent != null)
        {
            @ChildContent
        }
        else
        {
            @Value
        }
    </div>
</div>

@code {
    [Parameter] public string        Label        { get; set; } = "";
    [Parameter] public string?       Value        { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
