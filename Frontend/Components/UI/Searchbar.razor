@rendermode InteractiveServer
@inject NavigationManager Nav

@* NOTE: Popover + Calendar (shadcn/ui) have no direct Blazor equivalent.
   Replaced with native <input type="date"> styled to match the original button height and layout.
   The popover trigger button appearance is preserved via wrapper styling. *@

<div class="bg-card rounded-2xl shadow-elegant p-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 items-end">

        @* ── Check-in Date ── *@
        <div class="space-y-2">
            <label class="block text-sm font-medium text-muted-foreground">Check-in</label>
            <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none text-accent">
                    <i class="fas fa-calendar h-4 w-4"></i>
                </span>
                <input type="date"
                       value="@(CheckIn?.ToString("yyyy-MM-dd") ?? "")"
                       min="@DateTime.Today.ToString("yyyy-MM-dd")"
                       @onchange="OnCheckInChanged"
                       class="w-full h-12 rounded-md border border-input bg-white pl-9 pr-3 py-2 text-sm text-foreground border-border @(CheckIn is null ? "text-muted-foreground" : "")" />
            </div>
        </div>

        @* ── Check-out Date ── *@
        <div class="space-y-2">
            <label class="block text-sm font-medium text-muted-foreground">Check-out</label>
            <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none text-accent">
                    <i class="fas fa-calendar h-4 w-4"></i>
                </span>
                <input type="date"
                       value="@(CheckOut?.ToString("yyyy-MM-dd") ?? "")"
                       min="@((CheckIn.HasValue ? CheckIn.Value.AddDays(1) : DateTime.Today).ToString("yyyy-MM-dd"))"
                       @onchange="OnCheckOutChanged"
                       class="w-full h-12 rounded-md border border-input bg-white pl-9 pr-3 py-2 text-sm text-foreground border-border focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 @(CheckOut is null ? "text-muted-foreground" : "")" />
            </div>
        </div>

        @* ── Adults ── *@
        <div class="space-y-2">
            <label class="block text-sm font-medium text-muted-foreground">Adults</label>
            <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none text-accent">
                    <i class="fas fa-users h-4 w-4"></i>
                </span>
                <select @bind="Adults"
                        class="w-full h-12 rounded-md border border-input bg-white pl-9 pr-3 py-2 text-sm text-foreground border-border focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 appearance-none">
                    @foreach (var num in new[] { 1, 2, 3, 4 })
                    {
                        <option value="@num">@num Adult@(num > 1 ? "s" : "")</option>
                    }
                </select>
            </div>
        </div>

        @* ── Children ── *@
        <div class="space-y-2">
            <label class="block text-sm font-medium text-muted-foreground">Children</label>
            <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none text-accent">
                    <i class="fas fa-baby h-4 w-4"></i>
                </span>
                <select @bind="Children"
                        class="w-full h-12 rounded-md border border-input bg-white pl-9 pr-3 py-2 text-sm text-foreground border-border  appearance-none">
                    @foreach (var num in new[] { 0, 1, 2, 3 })
                    {
                        <option value="@num">@num Child@(num != 1 ? "ren" : "")</option>
                    }
                </select>
            </div>
        </div>

        @* ── Search Button ── *@
        <button @onclick="HandleSearch"
                disabled="@(!CheckIn.HasValue || !CheckOut.HasValue)"
                class="h-12 w-full inline-flex items-center justify-center gap-2 rounded-md bg-accent text-white text-sm font-semibold px-6 hover:bg-[var(--color-gold-hover,#b8973e)] transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
            <i class="fas fa-magnifying-glass h-4 w-4"></i>
            Search
        </button>

    </div>
</div>

@code {
    private DateTime? CheckIn { get; set; }
    private DateTime? CheckOut { get; set; }
    private int Adults { get; set; } = 2;
    private int Children { get; set; } = 0;

    private void OnCheckInChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var date))
        {
            CheckIn = date;
            // reset checkout if it is no longer after check-in
            if (CheckOut.HasValue && CheckOut.Value <= CheckIn.Value)
                CheckOut = null;
        }
        else
        {
            CheckIn = null;
        }
    }

    private void OnCheckOutChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var date))
            CheckOut = date;
        else
            CheckOut = null;
    }

    private void HandleSearch()
    {
        if (!CheckIn.HasValue || !CheckOut.HasValue) return;

        var query = $"checkIn={CheckIn.Value:yyyy-MM-dd}" +
                    $"&checkOut={CheckOut.Value:yyyy-MM-dd}" +
                    $"&adults={Adults}" +
                    $"&children={Children}";

        Nav.NavigateTo($"/searchresults?{query}");
    }
}