<div class="bg-card border border-border rounded-2xl p-6  shadow-sm">

    <h3 class="font-heading text-2xl text-primary mb-1">
        Inquire about this stay
    </h3>
    <p class="text-sm text-muted-foreground mb-6">
        Send a message or chat with us on WhatsApp.
    </p>

    <form class="space-y-3">

        <input type="text"
               placeholder="Your name"
               class="w-full px-4 py-3 rounded-lg border border-border bg-white text-sm text-foreground placeholder:text-muted-foreground outline-none focus:border-accent transition-colors" />

        <input type="tel"
               placeholder="Phone"
               class="w-full px-4 py-3 rounded-lg border border-border bg-white text-sm text-foreground placeholder:text-muted-foreground outline-none focus:border-accent transition-colors" />

        <input type="email"
               placeholder="Email"
               class="w-full px-4 py-3 rounded-lg border border-border bg-white text-sm text-foreground placeholder:text-muted-foreground outline-none focus:border-accent transition-colors" />

        <textarea placeholder="@($"Hello, I am interested in {ApartmentName}. Please share more details.")"
                  rows="4"
                  class="w-full px-4 py-3 rounded-lg border border-border bg-white text-sm text-foreground placeholder:text-muted-foreground outline-none focus:border-accent transition-colors resize-none"></textarea>

        <div class="space-y-2 pt-1">
            <button type="submit"
                    class="inline-flex items-center justify-center gap-2 w-full px-6 py-4 rounded-lg text-sm font-semibold bg-accent text-white hover:bg-accent/90 transition-colors">
                <i class="fa-solid fa-paper-plane text-[12px]"></i>
                Send Message
            </button>

            <button type="button"
                    class="inline-flex items-center justify-center gap-2 w-full px-6 py-4 rounded-lg text-sm font-semibold border border-border bg-background text-foreground hover:bg-muted/40 mt-2transition-colors">
                <i class="fa-regular fa-comment text-[13px]"></i>
                Chat on WhatsApp
            </button>
        </div>

    </form>
</div>

@code {
    [Parameter] public string ApartmentName { get; set; } = "";
}
