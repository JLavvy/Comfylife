@using Comfylife.Frontend.Models
@using Comfylife.Frontend.Data

<section class="relative bg-white py-24 border-b border-accent/10">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="flex items-center gap-3 text-[10px] font-bold uppercase tracking-[0.3em] text-accent mb-6"> 
            <span class="h-px w-10 bg-accent"></span>
            @Eyebrow
            <span class="h-px w-10 bg-accent"></span>
        </div>
        <h1 class="font-heading text-5xl lg:text-7xl text-primary mb-6 leading-tight">
            @if (!string.IsNullOrWhiteSpace(Highlight))
            {
                var parts = Title.Split(Highlight);
                @parts[0]
                <span class="italic text-accent">@Highlight</span>
                @if (parts.Length > 1)
                {
                    @parts[1]
                }
            }
            else
            {
                @Title
            }
        </h1>
        <p class="text-muted-foreground max-w-2xl text-lg leading-relaxed">
            @Description </p>
        </div>


    </section>

@code {
    [Parameter] public string Eyebrow { get; set; } = "";
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Highlight { get; set; } = "";
    [Parameter] public string Description { get; set; } = "";
}
