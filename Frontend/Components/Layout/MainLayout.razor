@inherits LayoutComponentBase

<div class="min-h-screen flex flex-col bg-white">

    <!-- Header -->
    <header class="bg-white shadow-sm sticky top-0 z-50">
        <nav class="w-full container mx-auto px-4 sm:px-2 md:px-14 max-w-[1440px]">
            <div class="flex h-20 items-center justify-between">

                <!-- Logo -->
                <NavLink href="/" class="flex items-center">
                    <img src="images/Logos/logo2.png" alt="ComfyLife" class="h-14 w-auto" />
                </NavLink>

                <!-- Desktop Navigation -->
                <div class="hidden lg:flex items-center gap-10">
                    <NavLink href="/" Match="NavLinkMatch.All" class="nav-link">
                        Home
                    </NavLink>

                    <NavLink href="/apartments" class="nav-link">
                        Apartments
                    </NavLink>

                    <NavLink href="/amenities" class="nav-link">
                        Amenities
                    </NavLink>

                    <NavLink href="/about" class="nav-link">
                        About
                    </NavLink>

                    <NavLink href="/contact" class="nav-link">
                        Contact
                    </NavLink>
                </div>

                <!-- CTA -->
                <div class="hidden lg:flex items-center gap-4">
                    <a href="tel:+1234567890"
                       class="flex items-center gap-2 text-sm text-muted-foreground hover:text-primary transition-colors">
                        <i class="fa-solid fa-phone"></i>
                        <span>+1 (234) 567-890</span>
                    </a>

                    <NavLink href="/booking"
                             class="bg-accent text-accent-foreground px-5 py-2 rounded-md hover:bg-accent/90 transition">
                        Book Now
                    </NavLink>
                </div>

                <!-- Mobile Button -->
                <button class="lg:hidden p-2" @onclick="ToggleMenu">
                    @if (mobileMenuOpen)
                    {
                        <i class="fa-solid fa-xmark text-xl"></i>
                    }
                    else
                    {
                        <i class="fa-solid fa-bars text-xl"></i>
                    }
                </button>
            </div>

            @if (mobileMenuOpen)
            {
                <div class="lg:hidden py-4 border-t border-border">
                    <div class="flex flex-col gap-4">

                        <NavLink href="/" Match="NavLinkMatch.All" @onclick="CloseMenu">foreground
                            Home
                        </NavLink>

                        <NavLink href="/apartments" @onclick="CloseMenu">
                            Apartments
                        </NavLink>

                        <NavLink href="/amenities" @onclick="CloseMenu">
                            Amenities
                        </NavLink>

                        <NavLink href="/about" @onclick="CloseMenu">
                            About
                        </NavLink>

                        <NavLink href="/contact" @onclick="CloseMenu">
                            Contact
                        </NavLink>

                        <NavLink href="/booking" @onclick="CloseMenu"
                                 class="bg-accent text-accent-foreground px-4 py-2 rounded-md text-center">
                            Book Now
                        </NavLink>
                    </div>
                </div>
            }
        </nav>
    </header>

    <!-- Main Content -->
    <main class="flex-1 bg-white">
        @Body
    </main>

    <!-- Footer -->
    <footer class="bg-primary text-white py-16">
        <div class="w-full container mx-auto px-4 sm:px-2 md:px-14 max-w-[1440px]">

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">

                <!-- Brand -->
                <div>
                    <div class="flex items-center gap-2 mb-4">
                        <img src="images/Logos/Logo2.jpg" alt="ComfyLife" class="h-14 w-auto" />
                    </div>

                    <p class="font-body text-sm">
                        A boutique residence shaped around the rituals of slow living and refined hospitality.
                    </p>
                </div>

                <!-- Links -->
                <div>
                    <h4 class="uppercase tracking-widest font-bold text-xs text-accent mb-5">
                        Explore
                    </h4>

                    <ul class="space-y-3 font-body text-sm">
                        <li>
                            <NavLink href="/">Home</NavLink>
                        </li>
                        <li>
                            <NavLink href="/apartments">Apartments</NavLink>
                        </li>
                        <li>
                            <NavLink href="/amenities">Amenities</NavLink>
                        </li>
                        <li>
                            <NavLink href="/about">About</NavLink>
                        </li>
                        <li>
                            <NavLink href="/contact">Contact</NavLink>
                        </li>
                    </ul>
                </div>

                <!-- Contact -->
                <div>
                    <h4 class="uppercase tracking-widest font-bold text-xs text-accent mb-5">
                        Contact
                    </h4>

                    <ul class="space-y-3 text-sm font-body">
                        <li>
                            <i class="fa-solid fa-location-dot mr-2"></i>
                            Nairobi, Kenya
                        </li>

                        <li>
                            <i class="fa-solid fa-phone mr-2"></i>
                            +254 700 000 000
                        </li>

                        <li>
                            <i class="fa-solid fa-envelope mr-2"></i>
                            info@comfylife.com
                        </li>
                    </ul>
                </div>

                <!-- Hours -->
                <div>
                    <h4 class="uppercase tracking-widest font-bold text-xs text-accent mb-5">
                        Office Hours
                    </h4>

                    <ul class="space-y-3 text-sm font-body">
                        <li class="flex justify-between">
                            <span>Mon - Fri</span>
                            <span>9 AM - 6 PM</span>
                        </li>

                        <li class="flex justify-between">
                            <span>Saturday</span>
                            <span>10 AM - 4 PM</span>
                        </li>

                        <li class="flex justify-between">
                            <span>Sunday</span>
                            <span>Appointment</span>
                        </li>
                    </ul>
                </div>

            </div>

            <div
                class="border-t border-white/10 mt-12 pt-6 flex flex-col md:flex-row justify-between items-center font-body">
                <p class="text-xs font-body">
                    © @DateTime.Now.Year ComfyLife BnB. All rights reserved.
                </p>

                <div class="flex gap-6 mt-4 md:mt-0">
                    <NavLink href="/privacy">Privacy</NavLink>
                    <NavLink href="/terms">Terms</NavLink>
                    <NavLink href="/adminlogin">Admin Login</NavLink>
                </div>
            </div>
        </div>
    </footer>

</div>

@code {
    private bool mobileMenuOpen;

    private void ToggleMenu()
    {
        mobileMenuOpen = !mobileMenuOpen;
    }

    private void CloseMenu()
    {
        mobileMenuOpen = false;
    }
}