@page "/contact"

<div>
    <PageHero Eyebrow="We're Here"
              Title="Get In Touch"
              Highlight="Touch"
              Description="Have a question, special request, or planning a longer stay? Our concierge team is one message away." />

    <section class="py-24 bg-white">
        <div class="max-w-7xl mx-auto px-6 lg:px-8 grid lg:grid-cols-12 gap-12 lg:gap-16">

            <div class="lg:col-span-5 space-y-10">
                <div>
                    <p class="text-[10px] uppercase tracking-[0.3em] text-accent font-bold mb-3">
                        Contact
                    </p>

                    <h2 class="font-heading text-4xl text-primary leading-tight mb-4">
                        Drop us a <span class="italic">line</span>
                    </h2>

                    <p class="text-muted-foreground leading-relaxed">
                        Whether it's an apartment inquiry, amenities question, or a bespoke booking — we'll respond personally within hours.
                    </p>
                </div>

                <div>
                    @foreach (var c in ContactInfo)
                    {
                        <div @key="c.Label" class="flex items-start gap-5 px-6 py-5 border-y border-border">
                            <i class="@($"{c.Icon} text-accent shrink-0 mt-0.5 text-sm")"></i>

                            <div>
                                <p class="text-[10px] uppercase tracking-[0.3em] font-bold text-muted-foreground mb-1">
                                    @c.Label
                                </p>

                                @if (!string.IsNullOrWhiteSpace(c.Href))
                                {
                                    <a href="@c.Href" class="text-sm text-foreground hover:text-accent transition-colors">
                                        @c.Value
                                    </a>
                                }
                                else
                                {
                                    <p class="text-sm text-foreground whitespace-pre-line leading-relaxed">
                                        @c.Value
                                    </p>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="lg:col-span-7">
                @if (IsSubmitted)
                {
                    <div class="border border-border bg-[#f7f2ee] px-6 sm:px-10 lg:px-14 py-12 lg:py-16 font-body">
                        <div class="flex flex-col items-start gap-3 py-10">
                            <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center">
                                <i class="fa-solid fa-check text-accent text-sm"></i>
                            </div>

                            <h3 class="font-heading text-3xl text-primary">
                                Message received
                            </h3>

                            <p class="text-muted-foreground text-sm leading-relaxed max-w-sm">
                                Thank you for reaching out. A member of our concierge team will be in touch within a few hours.
                            </p>

                            <button type="button"
                                    @onclick="ResetForm"
                                    class="mt-4 text-[10px] uppercase tracking-[0.3em] font-bold text-accent hover:text-primary transition-colors">
                                Send another message
                            </button>
                        </div>
                    </div>
                }
                else
                {
                    <EditForm Model="@FormData" OnValidSubmit="@HandleSubmit" FormName="ContactForm">
                        <DataAnnotationsValidator />

                        <div class="border border-border rounded-sm bg-[#f7f2ee] px-6 sm:px-10 lg:px-14 py-12 lg:py-16 font-body">
                            <p class="text-[10px] uppercase tracking-[0.45em] text-accent font-bold mb-6">
                                Send a Message
                            </p>

                            <h2 class="font-heading text-4xl lg:text-5xl text-primary leading-tight mb-12">
                                Let's start a <span class="italic">conversation</span>
                            </h2>

                            <div class="space-y-6">
                                <div class="grid md:grid-cols-2 gap-4 min-w-0">
                                    <div>
                                        <label class="block text-[10px] uppercase tracking-[0.35em] font-bold text-muted-foreground mb-3">
                                            Full Name <span class="text-accent">*</span>
                                        </label>

                                        <InputText @bind-Value="FormData.Name"
                                                   class="@InputClass("name")" />

                                        @if (Errors.ContainsKey("name"))
                                        {
                                            <p class="text-red-500 text-xs mt-2">@Errors["name"]</p>
                                        }
                                    </div>

                                    <div>
                                        <label class="block text-[10px] uppercase tracking-[0.35em] font-bold text-muted-foreground mb-3">
                                            Email <span class="text-accent">*</span>
                                        </label>

                                        <InputText type="email"
                                                   @bind-Value="FormData.Email"
                                                   class="@InputClass("email")" />

                                        @if (Errors.ContainsKey("email"))
                                        {
                                            <p class="text-red-500 text-xs mt-2">@Errors["email"]</p>
                                        }
                                    </div>
                                </div>

                                <div class="grid md:grid-cols-2 gap-4 min-w-0">
                                    <div>
                                        <label class="block text-[10px] uppercase tracking-[0.35em] font-bold text-muted-foreground mb-3">
                                            Phone
                                        </label>

                                        <InputText type="tel"
                                                   @bind-Value="FormData.Phone"
                                                   class="w-full h-12 bg-white border border-border rounded-sm px-4 text-sm text-foreground outline-none focus:border-accent transition-colors" />
                                    </div>

                                    <div>
                                        <label class="block text-[10px] uppercase tracking-[0.35em] font-bold text-muted-foreground mb-3">
                                            Subject <span class="text-accent">*</span>
                                        </label>

                                        <InputText @bind-Value="FormData.Subject"
                                                   class="@InputClass("subject")" />

                                        @if (Errors.ContainsKey("subject"))
                                        {
                                            <p class="text-red-500 text-xs mt-2">@Errors["subject"]</p>
                                        }
                                    </div>
                                </div>

                                <div>
                                    <label class="block text-[10px] uppercase tracking-[0.35em] font-bold text-muted-foreground mb-3">
                                        Message <span class="text-accent">*</span>
                                    </label>

                                    <InputTextArea @bind-Value="FormData.Message"
                                                   rows="6"
                                                   class="@TextAreaClass()" />

                                    @if (Errors.ContainsKey("message"))
                                    {
                                        <p class="text-red-500 text-xs mt-2">@Errors["message"]</p>
                                    }
                                </div>

                                <button type="submit"
                                        disabled="@IsSubmitting"
                                        class="w-full h-15 bg-primary px-6 py-4 text-primary-foreground text-[10px] uppercase tracking-[0.35em] font-bold rounded-sm hover:bg-accent transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                                    @(IsSubmitting ? "Sending…" : "Send Message")
                                </button>
                            </div>
                        </div>
                    </EditForm>
                }
            </div>

        </div>
    </section>
</div>

@code {
    private bool IsSubmitting;
    private bool IsSubmitted;
    private ContactFormModel FormData = new();
    private Dictionary<string, string> Errors = new();

    private readonly List<ContactInfoItem> ContactInfo = new()
    {
        new("fa-solid fa-location-dot", "Address", "123 Golf Course Drive\nParadise Valley, AZ 85253", null),
        new("fa-solid fa-phone", "Phone", "+1 (234) 567-890", "tel:+1234567890"),
        new("fa-solid fa-envelope", "Email", "info@golfview.com", "mailto:info@golfview.com"),
        new("fa-solid fa-clock", "Office Hours", "Mon – Fri: 9:00 – 18:00\nSat: 10:00 – 16:00\nSun: By Appointment", null)
    };

    private string InputClass(string field)
    {
        var border = Errors.ContainsKey(field) ? "border-red-500" : "border-border";

        return $"w-full h-12 bg-white border {border} rounded-sm px-4 text-sm text-foreground outline-none focus:border-accent transition-colors";
    }

    private string TextAreaClass()
    {
        var border = Errors.ContainsKey("message") ? "border-red-500" : "border-border";

        return $"w-full bg-white border {border} rounded-sm px-4 py-3 text-sm text-foreground outline-none focus:border-accent transition-colors resize-y";
    }

    private async Task HandleSubmit()
    {
        Errors.Clear();

        if (string.IsNullOrWhiteSpace(FormData.Name))
            Errors["name"] = "Full name is required.";

        if (string.IsNullOrWhiteSpace(FormData.Email))
            Errors["email"] = "A valid email address is required.";

        if (string.IsNullOrWhiteSpace(FormData.Subject))
            Errors["subject"] = "Please provide a subject.";

        if (string.IsNullOrWhiteSpace(FormData.Message))
            Errors["message"] = "Please include a message.";

        if (Errors.Any())
            return;

        IsSubmitting = true;

        await Task.Delay(1000);

        IsSubmitting = false;
        IsSubmitted = true;
    }

    private void ResetForm()
    {
        FormData = new();
        Errors = new();
        IsSubmitted = false;
    }

    private record ContactInfoItem(string Icon, string Label, string Value, string? Href);

    private class ContactFormModel
    {
        public string Name { get; set; } = "";
        public string Email { get; set; } = "";
        public string Phone { get; set; } = "";
        public string Subject { get; set; } = "";
        public string Message { get; set; } = "";
    }
}