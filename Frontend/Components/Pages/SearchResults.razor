@page "/searchresults"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.WebUtilities
@using Comfylife.Frontend.Models
@using Comfylife.Frontend.Data
@inject NavigationManager Nav

<div class="min-h-screen bg-background">
    <!-- Editorial header -->
    <section class="border-b border-border bg-muted/30">
        <div class="max-w-7xl mx-auto px-6 lg:px-8 py-12">
            <a href="/" class="inline-flex items-center gap-2 text-[10px] uppercase tracking-[0.3em] font-bold text-muted-foreground hover:text-accent mb-6">
                <i class="fas fa-arrow-left"></i> Back to Home
            </a>
            <div class="flex items-center gap-3 text-[10px] font-bold uppercase tracking-[0.3em] text-accent mb-4">
                <span class="h-px w-10 bg-accent"></span> Search Results
            </div>
            <h1 class="font-heading text-4xl lg:text-6xl text-primary leading-tight mb-6">
                Available <span class="italic text-accent">Stays</span>
            </h1>
            <div class="flex flex-wrap gap-3 text-xs">
                @if (!string.IsNullOrEmpty(CheckIn) && !string.IsNullOrEmpty(CheckOut))
                {
                    <div class="inline-flex items-center gap-2 bg-background border border-border px-4 py-2">
                        <i class="fas fa-calendar text-accent"></i>
                        <span>@ParseDate(CheckIn).ToString("MMM dd, yyyy") – @ParseDate(CheckOut).ToString("MMM dd, yyyy")</span>
                        <span class="text-[10px] uppercase tracking-widest font-bold text-accent ml-1">
                            @Nights @(Nights == 1 ? "night" : "nights")
                        </span>
                    </div>
                }
                <div class="inline-flex items-center gap-2 bg-background border border-border px-4 py-2">
                    <i class="fas fa-users text-accent"></i>
                    <span>
                        @Adults @(Adults == 1 ? "Adult" : "Adults")@(Children > 0 ? $", {Children} {(Children == 1 ? "Child" : "Children")}" : "")
                    </span>
                </div>
            </div>
        </div>
    </section>

    <!-- Results -->
    <section class="py-16">
        <div class="max-w-7xl mx-auto px-6 lg:px-8">
            <p class="text-sm text-muted-foreground mb-10">
                <span class="font-heading text-2xl text-primary mr-2">@AvailableApartments.Count</span>
                @(AvailableApartments.Count == 1 ? "apartment" : "apartments") available for your stay
            </p>

            <div class="space-y-10">
                @for (int i = 0; i < AvailableApartments.Count; i++)
                {
                    var apt = AvailableApartments[i];
                    var pricePerNight = apt.NightlyRate;
                    var totalPrice = (long)pricePerNight * Nights;
                    var delay = i * 80;

                    <div class="grid lg:grid-cols-12 gap-8 items-center pb-10 border-b border-border last:border-0 animate-fade-up"
                         style="animation-delay: @(delay)ms">
                        <div class="lg:col-span-5 relative aspect-[4/3] overflow-hidden rounded-sm group">
                            <img src="/@apt.Image" alt="@apt.Name" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
                            <span class="absolute top-4 left-4 bg-accent text-accent-foreground px-3 py-1 text-[10px] uppercase tracking-widest font-bold">
                                @apt.Bedrooms Bedroom
                            </span>
                        </div>

                        <div class="lg:col-span-7 space-y-4">
                            <h3 class="font-heading text-3xl lg:text-4xl text-primary leading-tight">@apt.Name</h3>
                            <p class="text-foreground/70 leading-relaxed">@apt.Description</p>

                            <div class="flex flex-wrap gap-6 pt-4 border-t border-border text-xs text-muted-foreground">
                                <span class="flex items-center gap-2">
                                    <i class="fas fa-bed text-primary"></i> @apt.Beds
                                </span>
                                <span class="flex items-center gap-2">
                                    <i class="fas fa-users text-primary"></i> Max @apt.MaxGuests
                                </span>
                                <span>@apt.Size</span>
                            </div>

                            <div class="flex flex-wrap gap-x-4 gap-y-1 pt-2">
                                @foreach (var amenity in apt.Amenities.Take(5))
                                {
                                    <span class="inline-flex items-center gap-1 text-xs text-muted-foreground">
                                        <i class="fas fa-check text-accent"></i> @amenity
                                    </span>
                                }
                            </div>

                            <div class="flex items-end justify-between pt-4">
                                <div>
                                    <p class="text-[10px] uppercase tracking-widest text-muted-foreground">Per night</p>
                                    <p class="font-heading text-3xl text-primary">KES @pricePerNight.ToString("N0")</p>
                                    @if (Nights > 0)
                                    {
                                        <p class="text-xs text-muted-foreground mt-1">
                                            Total: <span class="font-semibold text-foreground">KES @totalPrice.ToString("N0")</span> · @Nights nights
                                        </p>
                                    }
                                </div>
                                <a href="/booking?apartment=@apt.Id&checkIn=@CheckIn&checkOut=@CheckOut&adults=@Adults&children=@Children"
                                   class="inline-flex items-center gap-1 rounded-sm uppercase tracking-widest text-xs font-bold bg-primary text-primary-foreground px-4 py-2 hover:bg-primary/90 transition-colors">
                                    Book Now <i class="fas fa-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (AvailableApartments.Count == 0)
            {
                <div class="border border-border p-16 text-center">
                    <p class="font-heading text-2xl text-primary mb-3">No apartments match your criteria</p>
                    <p class="text-sm text-muted-foreground mb-8">Try adjusting your dates or guest count.</p>
                    <a href="/"
                       class="inline-flex items-center rounded-sm uppercase tracking-widest text-xs font-bold border border-border px-4 py-2 hover:bg-muted transition-colors">
                        Modify Search
                    </a>
                </div>
            }
        </div>
    </section>
</div>

@code {
    private string? CheckIn { get; set; }
    private string? CheckOut { get; set; }
    private int Adults { get; set; } = 1;
    private int Children { get; set; } = 0;
    private int TotalGuests => Adults + Children;
    private int Nights { get; set; } = 0;

    private List<ApartmentListing> AvailableApartments { get; set; } = new();

    protected override void OnInitialized()
    {
        var uri = new Uri(Nav.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        CheckIn  = query.TryGetValue("checkIn",  out var ci) && ci.Count > 0  ? ci[0] : null;
        CheckOut = query.TryGetValue("checkOut", out var co) && co.Count > 0 ? co[0] : null;
        Adults   = query.TryGetValue("adults",   out var a)  && int.TryParse(a,  out var ap) ? ap : 1;
        Children = query.TryGetValue("children", out var ch) && int.TryParse(ch, out var cp) ? cp : 0;

        if (!string.IsNullOrEmpty(CheckIn) && !string.IsNullOrEmpty(CheckOut))
            Nights = (int)(ParseDate(CheckOut) - ParseDate(CheckIn)).TotalDays;

        AvailableApartments = ApartmentData.Apartments
            .Where(apt => (apt.MaxGuests > 0 ? apt.MaxGuests : 2) >= TotalGuests)
            .ToList();
    }

    private static DateTime ParseDate(string? dateStr) =>
        DateTime.TryParse(dateStr, out var result) ? result : DateTime.Today;
}