<!-- CTA -->
<section class="py-24 text-accent-foreground text-center">
    <div class="max-w-2xl mx-auto px-6">
        <h2 class="font-heading text-4xl lg:text-5xl mb-6">
            Need Help <span class="italic text-accent">Choosing</span>?
        </h2>

        <p class="opacity-80 mb-4">
            Reach out and we'll help you pick the right apartment for your stay.
        </p>

        <a href="/contact"
           class="inline-flex items-center justify-center rounded-sm uppercase tracking-widest text-xs font-bold px-6 py-4 mb-3 bg-primary text-accent hover:bg-primary/90 transition">
            Contact Us
        </a>
    </div>
</section>

@code {
    private List<ApartmentListing> Listings => ApartmentData.Apartments;
}