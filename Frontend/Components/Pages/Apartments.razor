@page "/apartments"
@using Comfylife.Frontend.Data
@using Comfylife.Frontend.Models

<PageHero Eyebrow="@($"{Listings.Count} Curated Listings")" Title="Our Apartments" Highlight="Apartments"
          Description="Fully furnished apartments in Kilimani — book by the night or by the month.">

</PageHero>

<!-- Listings — editorial split rows -->
<section class="py-24 bg-white border-y border-border">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="flex items-end justify-between mb-12 flex-wrap gap-4">
            <div>
                <p class="text-[10px] uppercase tracking-[0.3em] text-accent font-bold mb-3">
                    The Collection
                </p>

                <h2 class="font-heading text-4xl lg:text-5xl text-primary">
                    Browse Listings
                </h2>
            </div>

            <p class="text-sm text-muted-foreground">
                @Listings.Count listings available
            </p>
        </div>

        <div class="border-b border-border">
            @foreach (var item in Listings.Select((apt, index) => new { apt, index }))
            {
                <a href="@($"/apartments/{item.apt.Id}")" @key="item.apt.Id"
                   class="group grid lg:grid-cols-12 gap-8 lg:gap-12 items-stretch py-12 animate-fade-up"
                   style="animation-delay:@($"{item.index * 80}ms")">

                    <!-- Image -->
                    <div class="lg:col-span-5 relative overflow-hidden rounded-sm min-h-[360px]">
                        <img src="@item.apt.Image" alt="@item.apt.Name"
                             class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />

                        <div class="absolute top-4 left-4 flex gap-2">
                            <span
                                class="bg-background/90 backdrop-blur px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-foreground">
                                @item.apt.Bedrooms Bed
                            </span>

                            <span
                                class="bg-accent text-accent-foreground px-3 py-1 text-[10px] font-bold uppercase tracking-widest">
                                KES @item.apt.NightlyRate.ToString("N0")/nt
                            </span>
                        </div>
                    </div>

                    <!-- Content -->
                    <div class="lg:col-span-7 space-y-6">
                        <div class="flex items-center gap-3 text-[10px] font-bold uppercase tracking-[0.3em] text-accent">
                            <span class="h-px w-10 bg-accent"></span>
                            @item.apt.Tagline
                        </div>

                        <h3
                            class="font-heading text-3xl lg:text-5xl text-primary leading-tight group-hover:text-accent transition-colors">
                            @item.apt.Name
                        </h3>

                        <p class="flex items-center gap-2 text-sm text-muted-foreground">
                            <i class="fa-solid fa-location-dot text-accent"></i>
                            @item.apt.Location
                        </p>

                        <p class="text-foreground/70 max-w-xl leading-relaxed">
                            @item.apt.Description
                        </p>

                        <div class="flex flex-wrap gap-6 pt-4 border-t border-border text-xs text-muted-foreground">
                            <span class="flex items-center gap-2">
                                <i class="fa-solid fa-users text-primary"></i>
                                Max @item.apt.MaxGuests
                            </span>

                            <span class="flex items-center gap-2">
                                <i class="fa-solid fa-bed text-primary"></i>
                                @item.apt.Beds
                            </span>

                            <span class="flex items-center gap-2">
                                <i class="fa-solid fa-bath text-primary"></i>
                                @item.apt.Bathrooms Bath
                            </span>

                            <span class="flex items-center gap-2">
                                <i class="fa-solid fa-expand text-primary"></i>
                                @item.apt.Size
                            </span>
                        </div>

                        <div class="flex items-end justify-between pt-2 font-body">
                            <div>
                                <p class="text-[10px] uppercase tracking-widest text-muted-foreground">
                                    From
                                </p>

                                <p class="font-heading font-bold text-base text-foreground">
                                    KES @item.apt.NightlyRate.ToString("N0")
                                    <span class="text-sm text-muted-foreground font-body">
                                        /night
                                    </span>
                                </p>

                                <p class="text-xs text-muted-foreground font-body mt-1">
                                    or KES @item.apt.MonthlyRate.ToString("N0")/month
                                </p>
                            </div>

                            <span
                                class="text-xs uppercase tracking-widest font-bold text-primary border-b-2 border-accent inline-flex items-center gap-3 group-hover:gap-4 transition-all">
                                View Details
                                <i
                                class="fa-solid fa-arrow-right transition-all -translate-x-2 group-hover:translate-x-0"></i>
                            </span>
                        </div>
                    </div>

                </a>
            }
        </div>
    </div>
</section>

